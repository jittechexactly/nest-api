<%- include('./loader') %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"
        integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $('#mobile-menu-button').click(function () {
                $('.show-menu').toggleClass('hidden');
            });
            setTimeout(() => {
                $('.index_main').addClass('pt-15');
                $('.loading_animation').addClass('hidden');
            }, 600);

            const token = localStorage.getItem('access_token');
            const button = $('.user_start_btn');

            if (token) {
                button.html(`
                    <div class="relative group">
                        <button class="rounded bg-neutral-primary-soft border border-gray-100 px-2 py-1 text-blue-500 shadow-xs">
                            <i class="ri-user-line text-yellow-500"></i>
                            Dashboard
                        </button>
                    </div>
                `);
            } else {
                button.html(`
                    <a href="/web/auth/register"
                    class="bg-yellow-500 transition-all duration-300 text-white font-medium text-base py-2 px-4 rounded hover:bg-yellow-600">Get
                    Started<i class="ri-arrow-right-up-long-line ms-2"></i></a>
                `);
            }
        });
    </script>